params {
    data_path = "/vast/eande106/data/transfer/raw"
    tmpdir = "/scratch4/eande106/AndersenLab/tmp"
    mode = "inbred"
}

executor {
    queueSize=500
    submitRateLimit=10
}

process {

    withLabel: 'pb_mark_duplicates' {
        executor = "slurm"
        maxRetries = 3
        clusterOptions = "-A eande106 -e errlog.txt"
        queue = "parallel"
	conda = "/data/eande106/software/conda_envs/assemblynf_env"
    }

    withLabel: 'pb_assembly' {
        executor = "slurm"
        maxRetries = 3
        clusterOptions = "-A eande106 -e errlog.txt"
        queue = "parallel"
	conda = "/data/eande106/software/conda_envs/assemblynf_env"
    }
}
