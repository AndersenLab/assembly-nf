params {
    data_path = "/vast/eande106/data/transfer/raw"
    tmpdir = "/scratch4/eande106/AndersenLab/tmp"
    mode = "inbred"
    source = "default"
    blobtools = null
}

executor {
    queueSize=500
    submitRateLimit=10
}

process {

    withLabel: 'pb_mark_duplicates' {
        executor = "slurm"
        maxRetries = 3
        clusterOptions = "-A eande106 -e errlog.txt -N 1 -n 4"
        queue = "parallel"
	    conda = "/data/eande106/software/conda_envs/assemblynf_env"
    }

    withLabel: 'pb_assemble' {
        executor = "slurm"
        maxRetries = 3
        clusterOptions = "-A eande106 -e errlog.txt -N 1 -n 48"
        queue = "parallel"
	    conda = "/data/eande106/software/conda_envs/assemblynf_env"
    }

    withLabel: 'merge' {
        executor = "slurm"
        maxRetries = 3
        clusterOptions = "-A eande106 -e errlog.txt -N 1 -n 4"
        queue = "parallel"
        conda = "/data/eande106/software/conda_envs/assemblynf_env"
    }

    withLabel: 'gather_stats' {
        executor = "slurm"
        maxRetries = 3
        clusterOptions = "-A eande106 -e errlog.txt -N 1 -n 4"
        queue = "parallel"
        conda = "/data/eande106/software/conda_envs/assemblynf_env"
    }

    withLabel: 'blobtools' {
        executor = "slurm"
        maxRetries = 3
        clusterOptions = "-A eande106 -e errlog.txt -N 1 -n 36 --time=48:00:00"
        queue = "parallel"
        conda = "/data/eande106/software/conda_envs/blob"
    }
    
    withLabel: 'busco' {
        executor = "slurm"
        maxRetries = 3
        clusterOptions = "-A eande106 -e errlog.txt -N 1 -n 12"
        queue = "parallel"
        conda = "/data/eande106/software/conda_envs/busco"
    }
    
    withLabel: 'gather_statsFiltered' {
        executor = "slurm"
        maxRetries = 3
        clusterOptions = "-A eande106 -e errlog.txt -N 1 -n 4"
        queue = "parallel"
        conda = "/data/eande106/software/conda_envs/blob"
    }
    
}
